# ── Origen Dashboard · Variables de entorno ───────────────────────────────
# Copia este archivo a .env y ajusta los valores antes de levantar Docker

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=origen_dashboard
MYSQL_USER=origen_user
MYSQL_PASSWORD=

# JWT — genera con: openssl rand -base64 48
JWT_SECRET=

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# CORS — orígenes permitidos (0 y 1 para producción, 2 y 3 para local)
CORS_ORIGIN_0=https://tudominio.com
CORS_ORIGIN_1=
CORS_ORIGIN_2=http://127.0.0.1:3002
CORS_ORIGIN_3=http://127.0.0.1:3003
